# Dummy credentials for the research campaign.
#
# Every value here is SHAPE-VALID BUT FAKE. The point is to let
# credential-gated MCP servers initialise (so they stop crashing on
# startup) and then exercise their network / file / process side-effects
# under the sandbox's monitors. The values are not real credentials
# anywhere; any real API call made with them will fail with 401/403,
# and that failure is exactly the signal we want to observe.
#
# NEVER replace these with real credentials. The whole point is that
# the test is auditable: anyone reading this file can confirm none of
# the values are sensitive.

# --- GitHub family ---
GITHUB_TOKEN=ghp_FakeTestToken1234567890abcdef1234
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_FakeTestToken1234567890abcdef1234
GH_TOKEN=ghp_FakeTestToken1234567890abcdef1234

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-0000000000-0000000000000-FakeTestSlackBotToken1234
SLACK_TEAM_ID=T00000000
SLACK_APP_TOKEN=xapp-1-A00000000-0000000000000-FakeTestAppToken1234

# --- GitLab ---
GITLAB_PERSONAL_ACCESS_TOKEN=glpat-FakeTestGitlabToken1234567890
GITLAB_API_URL=https://gitlab.example.com/api/v4

# --- Notion ---
NOTION_API_KEY=secret_FakeTestNotionApiKey1234567890abcdef
NOTION_TOKEN=secret_FakeTestNotionApiKey1234567890abcdef

# --- Google ---
GOOGLE_MAPS_API_KEY=AIzaFakeTestGoogleMapsApiKey1234567890
GDRIVE_CREDS_PATH=/tmp/fake-gdrive-creds.json
GOOGLE_APPLICATION_CREDENTIALS=/tmp/fake-gcp-creds.json

# --- AWS ---
AWS_ACCESS_KEY_ID=AKIAFAKEACCESSKEY01
AWS_SECRET_ACCESS_KEY=FakeTestAwsSecretAccessKey1234567890abcdef
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_KB_ID=FAKEKB01

# --- Brave Search ---
BRAVE_API_KEY=BSAFakeTestBraveApiKey1234567890

# --- Postgres / Database connection strings ---
POSTGRES_CONNECTION_STRING=postgresql://test:fake@localhost:5432/test
POSTGRES_URL=postgresql://test:fake@localhost:5432/test
DATABASE_URL=postgresql://test:fake@localhost:5432/test
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=test
MYSQL_PASS=fake
MYSQL_DB=test

# --- Sentry ---
SENTRY_AUTH_TOKEN=FakeTestSentryAuthToken1234567890abcdef
SENTRY_DSN=https://fake@sentry.example.com/1

# --- Generic ---
ANTHROPIC_API_KEY=sk-ant-FakeTestAnthropicApiKey1234567890abcdef
OPENAI_API_KEY=sk-FakeTestOpenAiApiKey1234567890abcdef1234
HUGGINGFACE_API_KEY=hf_FakeTestHuggingFaceApiKey1234567890

# --- Kubernetes ---
KUBECONFIG=/tmp/fake-kubeconfig.yaml
